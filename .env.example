# Auth — required
JWT_SECRET=generate-a-long-random-string-here
REQUIRE_AUTH=true
ALLOWED_EMAIL_DOMAIN=fifthspace.com
COOKIE_SECURE=false

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Frontend only (set on Vercel)
# VITE_API_URL=https://your-api.onrender.com

# OpenAI — required for contract/invoice parsing accuracy and project chat.
# The billing-sheet-style invoice format (see README) can be parsed without a key;
# free-form T&M receipts, chat, and best-quality contract parsing all need one.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Review rule thresholds (optional overrides)
BILLED_WARNING_THRESHOLD=0.75
BILLED_CRITICAL_THRESHOLD=1.0
MAX_HOURS_PER_DAY=8
MAX_HOURS_PER_WEEK=40
